# PostgreSQL Database URL
# Format: postgres://<username>:<password>@<host>:<port>/<database_name>
DATABASE_URL=postgres://postgres:your_password@localhost:5432/sc_courier

# Server Port
PORT=5000

# SMTP Server Configuration (Optional - for ATR Email Approvals)
# If left blank, the server will automatically default to a free test Ethereal SMTP account.
SMTP_HOST=smtp.yourprovider.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@domain.com
SMTP_PASS=your_password

# Supabase Configuration (for ATR approvals & delivery scheduling)
SUPABASE_URL=https://your-supabase-id.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key
